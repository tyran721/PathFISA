{
  "name": "pathfisa",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "concurrently -n web,api -c cyan,magenta \"npm run dev:web\" \"npm run dev:api\"",
    "dev:web": "npm --prefix apps/web run dev",
    "dev:api": ".venv\\Scripts\\python.exe -m uvicorn app.main:app --reload --port 8000 --app-dir apps/api",
    "build": "npm --prefix apps/web run build",
    "check": "npm --prefix apps/web run check"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
